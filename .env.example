# --- Vaio (agente) ---
# OpenRouter: gateway con cadena de fallback (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Modelos (verificar nombres/precios al construir en openrouter.ai/models).
# Cadena de fallback: primario barato -> fallback -> free de última instancia.
OPENROUTER_MODELS=deepseek/deepseek-chat,google/gemini-flash-1.5,meta-llama/llama-3.3-70b-instruct:free

# Embeddings (decidir proveedor: OpenAI text-embedding-3-small u otro barato)
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
# Opcional: base URL del endpoint /embeddings (compatible con OpenAI).
# La dimensión del vector es FIJA en el schema Drizzle
# (apps/agent/src/adapters/db/schema.ts → EMBEDDING_DIM=1536); cambiar a un modelo de
# otra dimensión requiere editar esa constante + nueva migración.
EMBEDDINGS_BASE_URL=https://api.openai.com/v1

# Neon Postgres + pgvector (https://neon.tech) — connection string
DATABASE_URL=

# GitHub token read-only (perfil/repos públicos) — scope: public_repo/read:user
GITHUB_TOKEN=
GITHUB_USER=KevinJGV

# Last.fm (gustos musicales / now-playing) — mismas keys que el portafolio
LASTFM_API_KEY=
LASTFM_USER=

# Auth del agente: el proxy del portafolio manda este header; el agente lo valida.
AGENT_API_KEY=

# Server
PORT=8787

# --- Fase 2+ (placeholders) ---
# TELEGRAM_BOT_TOKEN=
# RESEND_API_KEY=
