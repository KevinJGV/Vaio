# --- Vaio (agente) ---
# OpenRouter: gateway con cadena de fallback (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Modelos (verificar nombres/precios al construir en openrouter.ai/models).
# Cadena de fallback: primario barato -> fallback -> free de última instancia.
OPENROUTER_MODELS=deepseek/deepseek-chat,google/gemini-flash-1.5,meta-llama/llama-3.3-70b-instruct:free

# Embeddings: van por OpenRouter (mismo provider que el chat). Modelo único multimodal
# `gemini-embedding-2` (texto+imagen+video+audio+PDF). Verificar slug exacto en
# openrouter.ai/models. Si dejás EMBEDDINGS_API_KEY vacío, el agente usa OPENROUTER_API_KEY.
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=google/gemini-embedding-2
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
# Dimensión FIJA en el schema Drizzle (schema.ts → EMBEDDING_DIM=1536): 3072 nativo truncado
# a 1536 vía Matryoshka (límite del índice HNSW de pgvector = 2000). Cambiarla = nueva migración.

# Neon Postgres + pgvector (https://neon.tech) — connection string
DATABASE_URL=

# GitHub token read-only (perfil/repos públicos) — scope: public_repo/read:user
GITHUB_TOKEN=
GITHUB_USER=

# Last.fm (gustos musicales / now-playing) — mismas keys que el portafolio
LASTFM_API_KEY=
LASTFM_USER=

# Auth del agente: el proxy del portafolio manda este header; el agente lo valida.
AGENT_API_KEY=

# Server
PORT=8787

# --- Observabilidad (logs estructurados a stdout — los captura Railway) ---
# Entorno: development|production|test. Railway setea production → logs en JSON.
NODE_ENV=development
# Nivel: trace|debug|info|warn|error|silent (default info).
LOG_LEVEL=info
# Formato: pretty (dev, con colores) | json (prod) | auto (pretty salvo en producción).
LOG_FORMAT=auto
# Loguear contenido CRUDO (prompts del usuario, args/output de tools, reasoning completo).
# OFF por defecto (privacidad/inyección). Poné "true" en dev para ver todo. Acepta true|1.
LOG_PROMPTS=false

# --- Memoria conversacional ---
# Modelo barato para el resumen rodante (default: la cola de OPENROUTER_MODELS).
SUMMARY_MODEL=
# Nº de mensajes acumulados que dispara el resumen (default 12) y cuántos recientes van verbatim (10).
SUMMARY_THRESHOLD=12
CONVERSATION_RECENT_LIMIT=10

# --- Compresión de contexto (Tier 1, determinístico — @vaio/compress) ---
# Comprime lo que se manda al modelo (resumen + turnos históricos + chunks de RAG) sin llamar a
# un modelo. ON salvo "false"/"0". Intensidad lite|full|ultra: conversación conservadora (lite),
# RAG más agresiva (full) porque es prosa larga del CV/portfolio.
COMPRESS_ENABLED=true
COMPRESS_INTENSITY_CONV=lite
COMPRESS_INTENSITY_RAG=full

# --- Multimodal: modelos POR MODALIDAD (cada tarea su modelo; ver openrouter.ai/models, cambian mensual) ---
# OpenRouter cubre transcripción/visión/voz por REST (el provider del AI SDK no los envuelve → fetch directo;
# fuente: https://openrouter.ai/openapi.json). Vaio queda single-provider.
# Fallback común (back-compat): si no setés VISION_MODELS/TRANSCRIBE_MODEL, se usa MULTIMODAL_MODELS.
MULTIMODAL_MODELS=google/gemini-2.5-flash-lite
# Visión (imagen→texto o nativa): cadena csv de chat con file-part. Vacía → MULTIMODAL_MODELS.
VISION_MODELS=google/gemini-2.5-flash-lite
# STT dedicado (audio→texto) vía POST /audio/transcriptions. Vacío → MULTIMODAL_MODELS[0].
# Verificado jun-2026: whisper-large-v3 (el más barato), whisper-1, openai/gpt-4o(-mini)-transcribe.
TRANSCRIBE_MODEL=openai/whisper-large-v3
# true → imágenes NATIVAS al modelo de chat (la cadena de chat DEBE ser vision-capaz).
# false (default) → se describen a texto con VISION_MODELS (robusto con cualquier cadena de chat).
MULTIMODAL_NATIVE_IMAGES=false
# Salida de voz (TTS) vía POST /audio/speech — CADENA de fallback client-side. Voz Y formato son
# POR-MODELO (no portables) → cada entrada es `model|voice|format`, se prueban en orden, la 1ª con audio gana;
# si todas fallan → texto. pcm se envuelve en WAV (Telegram no reproduce pcm crudo). Vacío → Vaio solo texto.
# Verificado jun-2026: kokoro-82m (voces af_bella/af_heart/am_adam, mp3) · gemini-3.1-flash-tts-preview
# (voz Zephyr, SOLO pcm). Voz omitida → "alloy"; formato omitido → "mp3". Confirmar slugs/voces en la
# galería (tab Speech; cambian mensual).
SPEECH_MODELS=hexgrad/kokoro-82m|af_bella|mp3,google/gemini-3.1-flash-tts-preview|Zephyr|pcm
# Base REST de OpenRouter (para /audio/* y /rerank). Default ok; cambiar solo si usás un proxy.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Límite de tamaño por adjunto (bytes). Default 20MB (= cap de getFile de Telegram).
MEDIA_MAX_BYTES=20971520

# --- Canal Telegram (webhook /tg) ---
# Con token + secret el webhook /tg se monta. Token del bot (@BotFather); secret arbitrario que
# validamos en el header X-Telegram-Bot-Api-Secret-Token. Registrar: setWebhook url=…/tg + secret_token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Allowlist OPCIONAL (csv de telegram user ids): vacío = acceso abierto (gating en el bot); con ids = whitelist.
TELEGRAM_ALLOWED_USER_IDS=
# Id de Telegram de Kevin (owner): SÓLO ese id es de confianza (perfil pleno/agéntico). Cualquier otro =
# visitante capado (Vaio lo presenta). Sin esto, nadie es owner. Obtené tu id con @userinfobot.
OWNER_TELEGRAM_ID=

# --- Fase 2+ (placeholders) ---
# RESEND_API_KEY=
