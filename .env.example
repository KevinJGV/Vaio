# --- Vaio (agente) ---
# OpenRouter: gateway con cadena de fallback (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Modelos (verificar nombres/precios al construir en openrouter.ai/models).
# Cadena de fallback: primario barato -> fallback -> free de última instancia.
OPENROUTER_MODELS=deepseek/deepseek-chat,google/gemini-flash-1.5,meta-llama/llama-3.3-70b-instruct:free
# App attribution: identifica la app en el dashboard de OpenRouter (sin esto aparece "unknown").
# APP_NAME → header X-Title; APP_URL → HTTP-Referer. Aplica al provider Y a las llamadas REST (audio/*).
APP_NAME=Vaio - Local
APP_URL=https://vindevsito.dev

# Embeddings: van por OpenRouter (mismo provider que el chat). Modelo único multimodal
# `gemini-embedding-2` (texto+imagen+video+audio+PDF). Verificar slug exacto en
# openrouter.ai/models. Si dejás EMBEDDINGS_API_KEY vacío, el agente usa OPENROUTER_API_KEY.
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=google/gemini-embedding-2
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
# Dimensión FIJA en el schema Drizzle (schema.ts → EMBEDDING_DIM=1536): 3072 nativo truncado
# a 1536 vía Matryoshka (límite del índice HNSW de pgvector = 2000). Cambiarla = nueva migración.

# Neon Postgres + pgvector (https://neon.tech) — connection string
DATABASE_URL=

# GitHub token read-only (perfil/repos públicos) — scope: public_repo/read:user
GITHUB_TOKEN=
GITHUB_USER=

# Zona horaria de Kevin (IANA) para el "sentido del ahora" — Vaio sabe la fecha/hora actual. Default America/Bogota.
OWNER_TIMEZONE=America/Bogota

# Last.fm (gustos musicales / now-playing) — mismas keys que el portafolio
LASTFM_API_KEY=
LASTFM_USER=

# Conector WakaTime — tiempo de programación medido (wakatime.com/settings/api-key)
WAKATIME_API_KEY=
# Conector Steam — qué juega / favoritos (steamcommunity.com/dev/apikey + tu SteamID64; perfil de juegos público)
STEAM_API_KEY=
STEAM_ID=

# "Vaio se nutre solo" (pasos 1+2): repos CRUDOS (md + código) a ingerir, csv "owner/repo[@branch]".
# Incluye el propio repo (self-awareness). Vacío = no corre. Reusa GITHUB_TOKEN. Excluye node_modules/
# dist/lockfiles/binarios y SIEMPRE secrets (.env*/*.pem/*.key/credenciales). Branch omitido = default del repo.
RAW_SOURCE_REPOS=KevinJGV/Vaio,KevinJGV/KevinJGV
# Cap de tamaño por archivo (bytes; default 100KB) y de chunks por repo (default 800). Descartes se loguean.
RAW_FILE_MAX_BYTES=
RAW_REPO_MAX_CHUNKS=
# Sync de repos: umbral de archivos para sync inline en el chat (más → background; default 20); TTL del freshness
# gate en minutos (no re-chequea un repo si lo hizo hace menos; default 10); fuerza re-index full en `pnpm sync`
# (re-embebe todo; para re-index puntual tras cambios de chunker o poblar lo que un cap bajo dejó afuera).
SYNC_INLINE_MAX_FILES=
FRESHNESS_TTL_MINUTES=
SYNC_FORCE_FULL=

# Auth del agente: el proxy del portafolio manda este header; el agente lo valida.
AGENT_API_KEY=

# Server
PORT=8787

# --- Observabilidad (logs estructurados a stdout — los captura Railway) ---
# Entorno: development|production|test. Railway setea production → logs en JSON.
NODE_ENV=development
# Nivel: trace|debug|info|warn|error|silent (default info).
LOG_LEVEL=info
# Formato: pretty (dev, con colores) | json (prod) | auto (pretty salvo en producción).
LOG_FORMAT=auto
# Loguear contenido CRUDO (prompts del usuario, args/output de tools, reasoning completo).
# OFF por defecto (privacidad/inyección). Poné "true" en dev para ver todo. Acepta true|1.
LOG_PROMPTS=false
# Persistir la traza de cada turno en Postgres (tabla trace_events) si hay DB. ON salvo "false"/"0".
# Contenido COMPLETO en DB (privada); la redacción de LOG_PROMPTS es solo para stdout.
TRACE_PERSIST=true

# --- Memoria conversacional ---
# Modelo(s) barato(s) para el resumen rodante. Cadena csv → fallback server-side (default: la cola de OPENROUTER_MODELS).
SUMMARY_MODELS=
# Nº de mensajes acumulados que dispara el resumen (default 12) y cuántos recientes van verbatim (10).
SUMMARY_THRESHOLD=12
CONVERSATION_RECENT_LIMIT=10

# --- Compresión de contexto (Tier 1, determinístico — @vaio/compress) ---
# Comprime lo que se manda al modelo (resumen + turnos históricos + chunks de RAG) sin llamar a
# un modelo. ON salvo "false"/"0". Solo comprime el CONTEXTO conversacional (resumen + turnos
# históricos); intensidad lite|full|ultra (conservadora por defecto). El RAG NO se comprime: iba
# verbatim al modelo para no mutilar el grounding (prosa/código) por un ahorro marginal.
COMPRESS_ENABLED=true
COMPRESS_INTENSITY_CONV=lite

# --- Multimodal: cada modalidad su modelo EXPLÍCITO (vacío = esa modalidad OFF) ---
# OpenRouter cubre transcripción/visión/voz por REST (el provider del AI SDK no los envuelve → fetch directo;
# fuente: https://openrouter.ai/openapi.json). Vaio queda single-provider. Verificar slugs en openrouter.ai/models.
# Visión (imagen→texto o nativa): cadena csv de chat con file-part. Vacía → visión OFF.
VISION_MODELS=google/gemini-2.5-flash-lite
# STT dedicado (audio→texto) vía POST /audio/transcriptions. CADENA csv → fallback CLIENT-SIDE (se prueba
# cada modelo en orden; el endpoint es single-model, sin el fallback server-side del chat). Vacío → STT OFF.
# Verificado jun-2026: whisper-large-v3 (el más barato), whisper-1, openai/gpt-4o(-mini)-transcribe.
TRANSCRIBE_MODELS=openai/whisper-large-v3,openai/whisper-1
# true → imágenes NATIVAS al modelo de chat (la cadena de chat DEBE ser vision-capaz).
# false (default) → se describen a texto con VISION_MODELS (robusto con cualquier cadena de chat).
MULTIMODAL_NATIVE_IMAGES=false
# Salida de voz (TTS) vía POST /audio/speech — CADENA de fallback client-side. Voz Y formato son
# POR-MODELO (no portables) → cada entrada es `model|voice|format`, se prueban en orden, la 1ª con audio gana;
# si todas fallan → texto. pcm se envuelve en WAV (Telegram no reproduce pcm crudo). Vacío → Vaio solo texto.
# Verificado jun-2026: kokoro-82m (voces af_bella/af_heart/am_adam, mp3) · gemini-3.1-flash-tts-preview
# (voz Zephyr, SOLO pcm). Voz omitida → "alloy"; formato omitido → "mp3". Confirmar slugs/voces en la
# galería (tab Speech; cambian mensual).
SPEECH_MODELS=hexgrad/kokoro-82m|em_santa|mp3,google/gemini-3.1-flash-tts-preview|Sulafat|pcm
# Rerank (2ª etapa del RAG): recupera wide-K por vector → rerankea (query+chunk juntos) → recorta al top-K
# del canal. Mejora QUÉ entra al contexto (grounding), clave con corpus grande de código. csv de fallback
# client-side (REST /rerank, single-provider). Vacío → OFF (cae a vector top-K). Verificá slug/precio en
# openrouter.ai/models (tab Rerank).
RERANK_MODELS=cohere/rerank-v3.5
# Pool de candidatos que se recupera por vector y se manda a rerankear (vacío → 30).
RERANK_CANDIDATES=
# Facts en el retrieval: los hechos curados (owner-confirmed) se recuperan SIEMPRE aparte y se anteponen al
# contexto (tan importantes como los repos; no los tapan los chunks). MAX = cuántos incluir; DISTANCE = distancia
# coseno máx para que un fact cuente como relevante a la query (generoso). Defaults 4 / 0.7.
FACT_RETRIEVE_MAX=
FACT_RETRIEVE_DISTANCE=
# Tendencias de conectores ("trends"): acumula snapshots en el tiempo y deriva un chunk de patrón (con
# clasificación) cada ingest. Vacío/OFF; "true"/"1" para activar. TREND_MODELS = modelo de derivación (csv; cae
# a SUMMARY_MODELS / chat). TREND_RETENTION = cuántos snapshots guardar por fuente (default 12).
TRENDS_ENABLED=
TREND_MODELS=
TREND_RETENTION=
# Adjudicación de conflictos de facts (saveFact): al proponer un hecho, busca facts confirmados cercanos para que
# Vaio decida si reemplaza a uno viejo (invalida bi-temporal + linaje). DISTANCE = distancia coseno máx para
# "cercano" (default 0.45, generoso — el modelo/owner filtran la contradicción real). CANDIDATES = máx a sugerir.
FACT_CONFLICT_DISTANCE=
FACT_CONFLICT_CANDIDATES=
# Base REST de OpenRouter (para /audio/* y /rerank). Default ok; cambiar solo si usás un proxy.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Límite de tamaño por adjunto (bytes). Default 20MB (= cap de getFile de Telegram).
MEDIA_MAX_BYTES=20971520

# --- Canal Telegram (webhook /tg) ---
# Con token + secret el webhook /tg se monta. Token del bot (@BotFather); secret arbitrario que
# validamos en el header X-Telegram-Bot-Api-Secret-Token. Registrar: setWebhook url=…/tg + secret_token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Allowlist OPCIONAL (csv de telegram user ids): vacío = acceso abierto (gating en el bot); con ids = whitelist.
TELEGRAM_ALLOWED_USER_IDS=
# Id de Telegram de Kevin (owner): SÓLO ese id es de confianza (perfil pleno/agéntico). Cualquier otro =
# visitante capado (Vaio lo presenta). Sin esto, nadie es owner. Obtené tu id con @userinfobot.
OWNER_TELEGRAM_ID=
# Streaming en Telegram: muestra el texto PARCIAL en vivo en chats privados (sendMessageDraft); en grupos/topics
# o si el bot no lo soporta → cae a "escribiendo…". Vacío/ON; "false"/"0" para apagarlo sin redeploy.
TELEGRAM_DRAFT_STREAMING=

# --- Fase 2+ (placeholders) ---
# RESEND_API_KEY=
