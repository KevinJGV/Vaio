# --- Vaio (agente) ---
# OpenRouter: gateway con cadena de fallback (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Modelos (verificar nombres/precios al construir en openrouter.ai/models).
# Cadena de fallback: primario barato -> fallback -> free de última instancia.
OPENROUTER_MODELS=deepseek/deepseek-chat,google/gemini-flash-1.5,meta-llama/llama-3.3-70b-instruct:free

# Embeddings: van por OpenRouter (mismo provider que el chat). Modelo único multimodal
# `gemini-embedding-2` (texto+imagen+video+audio+PDF). Verificar slug exacto en
# openrouter.ai/models. Si dejás EMBEDDINGS_API_KEY vacío, el agente usa OPENROUTER_API_KEY.
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=google/gemini-embedding-2
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
# Dimensión FIJA en el schema Drizzle (schema.ts → EMBEDDING_DIM=1536): 3072 nativo truncado
# a 1536 vía Matryoshka (límite del índice HNSW de pgvector = 2000). Cambiarla = nueva migración.

# Neon Postgres + pgvector (https://neon.tech) — connection string
DATABASE_URL=

# GitHub token read-only (perfil/repos públicos) — scope: public_repo/read:user
GITHUB_TOKEN=
GITHUB_USER=

# Last.fm (gustos musicales / now-playing) — mismas keys que el portafolio
LASTFM_API_KEY=
LASTFM_USER=

# Auth del agente: el proxy del portafolio manda este header; el agente lo valida.
AGENT_API_KEY=

# Server
PORT=8787

# --- Observabilidad (logs estructurados a stdout — los captura Railway) ---
# Entorno: development|production|test. Railway setea production → logs en JSON.
NODE_ENV=development
# Nivel: trace|debug|info|warn|error|silent (default info).
LOG_LEVEL=info
# Formato: pretty (dev, con colores) | json (prod) | auto (pretty salvo en producción).
LOG_FORMAT=auto
# Loguear contenido CRUDO (prompts del usuario, args/output de tools, reasoning completo).
# OFF por defecto (privacidad/inyección). Poné "true" en dev para ver todo. Acepta true|1.
LOG_PROMPTS=false

# --- Memoria conversacional ---
# Modelo barato para el resumen rodante (default: la cola de OPENROUTER_MODELS).
SUMMARY_MODEL=
# Nº de mensajes acumulados que dispara el resumen (default 12) y cuántos recientes van verbatim (10).
SUMMARY_THRESHOLD=12
CONVERSATION_RECENT_LIMIT=10

# --- Canal Telegram (webhook /tg) ---
# Si falta cualquiera de las tres, el webhook /tg NO se monta. Token del bot (@BotFather);
# secret arbitrario que validamos en el header X-Telegram-Bot-Api-Secret-Token; allowlist de
# tu(s) telegram user id(s) (csv). Registrar el webhook: setWebhook con url=…/tg + secret_token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=

# --- Fase 2+ (placeholders) ---
# RESEND_API_KEY=
