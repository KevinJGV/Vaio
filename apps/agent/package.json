{
  "name": "@vaio/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @vaio/contracts build && tsx watch src/index.ts",
    "build": "pnpm --filter @vaio/contracts build && tsc",
    "start": "node dist/index.js",
    "ingest": "tsx src/ingest.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/adapters/db/migrate.ts",
    "db:migrate:prod": "node dist/adapters/db/migrate.js",
    "db:push": "drizzle-kit push",
    "db:push:watch": "tsx src/adapters/db/push-watch.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2",
    "@openrouter/ai-sdk-provider": "^2",
    "@vaio/compress": "workspace:*",
    "@vaio/contracts": "workspace:*",
    "ai": "^6",
    "dotenv": "^17",
    "drizzle-orm": "^0.45.2",
    "hono": "^4",
    "pg": "^8",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@types/pg": "^8",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4",
    "typescript": "^6",
    "vite": "^8.0.16",
    "vitest": "^4"
  }
}
