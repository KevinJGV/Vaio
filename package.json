{
  "name": "vaio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo de Vaio — agente personal de IA de Kevin (apps/agent) + contratos compartidos (packages/contracts).",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @vaio/agent dev",
    "ingest": "pnpm --filter @vaio/agent ingest",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "typescript": "^6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
